<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Login System</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <h1>🔐 Secure Login System</h1>
        
        <% if (user) { %>
            <div class="welcome">
                <h2>Welcome, <%= user.username %>!</h2>
                <div class="user-info">
                    <p><strong>Email:</strong> <%= user.email %></p>
                </div>
                <div class="actions">
                    <a href="/user/profile" class="btn">View Profile</a>
                    <a href="/2fa.html" class="btn">Manage 2FA</a>
                    <form action="/auth/logout" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-danger">Logout</button>
                    </form>
                </div>
            </div>
        <% } else { %>
            <div class="auth-container">
                <div class="form-section">
                    <h2>Login</h2>
                    <form id="loginForm">
                        <div class="form-group">
                            <input type="text" id="username" placeholder="Username" required>
                        </div>
                        <div class="form-group">
                            <input type="password" id="password" placeholder="Password" required>
                        </div>
                        <button type="submit" class="btn">Login</button>
                    </form>
                    <p>Don't have an account? <a href="/register.html">Register here</a></p>
                </div>
                
                <div class="divider"></div>
                
                <div class="form-section">
                    <h2>Register</h2>
                    <p class="info-text">Create a new account to get started</p>
                    <a href="/register.html" class="btn btn-secondary">Go to Registration</a>
                </div>
            </div>
        <% } %>
    </div>

    <script src="/js/main.js"></script>
</body>
</html>
